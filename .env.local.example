# Copy this file to .env.local for local dev, and add the same keys
# in Vercel's Project Settings -> Environment Variables for production.

# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of emails allowed to sign into /admin
ADMIN_EMAILS=you@example.com

# Random secret string; Vercel Cron sends it as a Bearer token automatically
# once set in Project Settings -> Environment Variables (see vercel.json)
CRON_SECRET=
